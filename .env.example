# ============================================
# Bansari Homeopathy - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# ============================================
# Application
# ============================================
APP_ENV=production

# ============================================
# Database (MySQL)
# ============================================
DB_HOST=localhost
DB_PORT=3307
DB_NAME=bansari_clinic
DB_USER=root
DB_PASS=

# ============================================
# Frontend URL (for CORS)
# ============================================
# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# Comma-separated list of allowed origins (optional, FRONTEND_URL is used if not set)
# ALLOWED_ORIGINS=https://vercel.app,https://your-domain.com

# ============================================
# JWT Settings
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ============================================
# Email / SMTP Settings
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Bansari Homeopathy Clinic <noreply@yourdomain.com>
EMAIL_REPLY_TO=info@yourdomain.com

# ============================================
# WhatsApp API (Optional)
# ============================================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=appointment_reminder
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ============================================
# SMS Gateway (Optional)
# ============================================
SMS_GATEWAY_URL=https://api.sms-provider.com/send
SMS_API_KEY=
SMS_FROM_NUMBER=MEDICN

# ============================================
# Admin API Key
# ============================================
ADMIN_API_KEY=your-admin-api-key-change-this

