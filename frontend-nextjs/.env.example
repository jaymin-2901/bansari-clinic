# ============================================================
# Bansari Homeopathy Clinic – Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# ─── Database (MySQL) ───
DATABASE_URL="mysql://root:@localhost:3307/bansari_clinic"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_SECRET="generate-a-random-64-char-secret-here"

# ─── WhatsApp Cloud API (Meta Business) ───
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_TEMPLATE_NAME="appointment_reminder"
WHATSAPP_TEMPLATE_LANGUAGE="en"

# ─── Email (SMTP / Nodemailer) ───
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Bansari Homeopathy Clinic <noreply@bansarihomeopathy.com>"
EMAIL_REPLY_TO="info@bansarihomeopathy.com"

# ─── Clinic Info ───
CLINIC_NAME="Bansari Homeopathy Clinic"
CLINIC_PHONE="+91 98765 43210"
CLINIC_ADDRESS="Near City Hospital, Main Road, Ahmedabad, Gujarat 380001"

# ─── Cron Settings ───
CRON_SECRET="your-cron-secret-key-here"
REMINDER_HOURS_BEFORE=24
CRON_INTERVAL_MINUTES=30

# ─── Admin API Key (for server-to-server auth) ───
ADMIN_API_KEY="your-admin-api-key-here"

# ─── PHP Backend URL (existing) ───
PHP_BACKEND_URL="http://localhost:8080"
NEXT_PUBLIC_API_URL="/api/clinic"
NEXT_PUBLIC_BACKEND_URL="http://localhost:8080"
